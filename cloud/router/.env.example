FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_VERIFICATION_TOKEN=xxxx
FEISHU_ENCRYPT_KEY=
# 平台Hermes Gateway -> router的入站鉴权头 x-ingress-secret
HERMES_INGRESS_SECRET=replace-with-random-secret
# Wrapper投递到router的规范化事件入口
HERMES_ROUTER_INGRESS_URL=http://router:8000/ingress/hermes-event

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Feishu Drive OAuth callback base (must match cloud/api API_BASE_URL)
API_BASE_URL=https://api.matrix.air7.fun
