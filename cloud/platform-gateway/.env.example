# Feishu credentials — ONLY held in this service
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Supabase for user/device resolution
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Internal LLM Gateway
GATEWAY_URL=http://gateway:4000/v1
GATEWAY_KEY=your-gateway-master-key

# Cloudflare R2 fallback (optional, for large files)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pi-matrix
R2_PUBLIC_URL=

# Session storage path inside container
SESSIONS_DIR=/app/sessions
API_BASE_URL=https://relay.air7.fun/pm/api
DASHBOARD_URL=https://matrix.air7.fun

# Executor call timeout (seconds)
EXECUTOR_TIMEOUT=180

# Optional: comma-separated open_ids to allow. Empty = allow all bound users.
ALLOWED_USERS=
