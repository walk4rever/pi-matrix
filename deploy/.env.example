# Supabase (shared with ai-pulse)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Feishu
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# LLM Gateway
ARK_API_KEY=your-volcengine-ark-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GATEWAY_MASTER_KEY=change-me-strong-random-key

# Orchestrator → hermes containers
GATEWAY_KEY=${GATEWAY_MASTER_KEY}
HERMES_MODEL=default
ROUTER_REPLY_URL=http://router:8000/reply
GATEWAY_URL=http://gateway:4000/v1
