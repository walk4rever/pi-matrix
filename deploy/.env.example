# Supabase (shared with ai-pulse)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# Feishu (ONLY message holds these credentials)
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Feishu Drive OAuth (required scope: drive:drive)
# Register callback URL in Feishu app: https://api.matrix.air7.fun/feishu/drive/callback
API_BASE_URL=https://relay.air7.fun/pm/api
DASHBOARD_URL=https://matrix.air7.fun

# Cloudflare R2 fallback (optional, for large files)
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=pi-matrix
R2_PUBLIC_URL=

# LLM
AI_API_KEY=your-api-key
AI_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_PRIMARY_MODEL=deepseek-v3.2
AI_VISION_MODEL=kimi-k2.5

# Gateway internal auth
GATEWAY_MASTER_KEY=change-me-strong-random-key

# Orchestrator → executor containers (internal docker network)
GATEWAY_KEY=${GATEWAY_MASTER_KEY}
HERMES_MODEL=default
GATEWAY_URL=http://gateway:4000/v1

# Message service (Feishu adapter + session router)
PLATFORM_GATEWAY_URL=http://message:8000

# Hermes auxiliary vision (for vision_analyze / browser_vision in user containers)
AUXILIARY_VISION_PROVIDER=main
AUXILIARY_VISION_MODEL=vision
AUXILIARY_VISION_BASE_URL=http://gateway:4000/v1
AUXILIARY_VISION_API_KEY=${GATEWAY_MASTER_KEY}

# Optional browser cloud providers (local Chromium + agent-browser also works without these)
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=
# BROWSER_USE_API_KEY=
# TAVILY_API_KEY=
# FIRECRAWL_API_KEY=
