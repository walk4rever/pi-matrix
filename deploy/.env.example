# Database
POSTGRES_PASSWORD=change-me-strong-password

# Supabase (if using hosted) or local postgres connection
SUPABASE_URL=http://postgres:5432
SUPABASE_SERVICE_KEY=your-service-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Feishu
FEISHU_APP_ID=cli_xxxx
FEISHU_APP_SECRET=xxxx
FEISHU_VERIFICATION_TOKEN=
FEISHU_ENCRYPT_KEY=

# Hermes
HERMES_MODEL=anthropic/claude-haiku-4-5
ANTHROPIC_API_KEY=your-key

# Router public reply URL (your domain)
ROUTER_REPLY_URL=https://api.your-domain.com/reply
